cabal-version:      3.0
name:               narsil
version:            0.1.0.0
synopsis:           A type checker, linter, and language server for Nix
description:        Hindley-Milner type inference for the Nix expression language
                    (row-polymorphic records, union types, a typed model of the
                    NixOS module system) with a corpus-verified false-positive
                    floor across all of nixpkgs, plus policy linting, embedded
                    bash analysis, and an LSP server.
license:            MIT
license-file:       LICENSE
author:             Hypermodern Consulting
maintainer:         https://github.com/hypermodern-consulting/narsil
homepage:           https://github.com/hypermodern-consulting/narsil
bug-reports:        https://github.com/hypermodern-consulting/narsil/issues
category:           Development
build-type:         Simple

common warnings
    ghc-options: -Wall -Werror -Wcompat -Widentities -Wincomplete-record-updates -Wincomplete-uni-patterns -Wmissing-export-lists -Wmissing-home-modules -Wpartial-fields -Wredundant-constraints

-- Deep-vendored nixfmt (RFC 166), MPL-2.0. Source from nixfmt 1.3.1 under
-- vendor/nixfmt/ (see vendor/nixfmt/LICENSE), brought into our tree as
-- first-class code: it builds under OUR -Wall -Werror flags (modified where
-- needed; changes to these MPL files are themselves MPL). We format via
-- Nixfmt.format for byte-exact parity with the nixfmt binary, then diverge by
-- editing these modules directly.
library nixfmt-vendored
    import:           warnings
    visibility:       private
    exposed-modules:
        Nixfmt
        Nixfmt.Lexer
        Nixfmt.Parser
        Nixfmt.Parser.Float
        Nixfmt.Predoc
        Nixfmt.Pretty
        Nixfmt.Types
        Nixfmt.Util
    hs-source-dirs:   vendor/nixfmt
    default-language: Haskell2010
    -- nixfmt's Pretty/parser instances are orphans by design (the Pretty class
    -- lives in Predoc, the AST types in Types); de-orphaning would mean merging
    -- those modules. Upstream disables this warning for the same reason.
    ghc-options:      -Wno-orphans
    build-depends:
        base,
        containers,
        megaparsec,
        mtl,
        parser-combinators,
        scientific,
        text,
        transformers,
        pretty-simple

