    default-language: GHC2021

-- Differential soundness oracle: compares inferred types against
-- `nix-instantiate --eval` (builtins.typeOf). Skips cleanly when
-- nix-instantiate is unavailable (e.g. the sandboxed flake check).
test-suite narsil-oracle
    import:           warnings
    type:             exitcode-stdio-1.0
    main-is:          Oracle.hs
    build-depends:
        base >= 4.16 && < 4.21,
        directory >= 1.3 && < 1.4,
        filepath >= 1.4 && < 1.6,
        hnix >= 0.17 && < 0.18,
        narsil,
        process >= 1.6 && < 1.7,
        temporary >= 1.3 && < 1.4,
        text >= 2.0 && < 2.2
    hs-source-dirs:   test
    default-language: GHC2021

-- The L-size differential oracle: sweep all of (pinned) nixpkgs through the
-- real check pipeline, ratcheting outcome counts against a committed baseline.
-- Run on demand / nightly, not part of `cabal test`:
--   cabal run narsil-oracle-sweep -- --sample 2000
--   cabal run narsil-oracle-sweep -- --write-baseline
executable narsil-oracle-fuzz
    import:           warnings
    main-is:          OracleFuzz.hs
    build-depends:
        base >= 4.16 && < 4.21,
        narsil,
        process >= 1.6 && < 1.7,
        QuickCheck >= 2.14 && < 2.16,
        text >= 2.0 && < 2.2
    hs-source-dirs:   test
    default-language: GHC2021
    ghc-options: -threaded -rtsopts "-with-rtsopts=-N"

executable narsil-oracle-sweep
    import:           warnings
    main-is:          OracleSweep.hs
    build-depends:
        aeson >= 2.0 && < 2.3,
        async >= 2.2 && < 2.3,
        base >= 4.16 && < 4.21,
        base16-bytestring >= 1.0 && < 1.1,
        containers >= 0.6 && < 0.8,
        cryptohash-sha256 >= 0.11 && < 0.12,
        directory >= 1.3 && < 1.4,
        filepath >= 1.4 && < 1.6,
        lsp-types >= 2.3 && < 2.4,
        narsil,
        text >= 2.0 && < 2.2
    hs-source-dirs:   test
    default-language: GHC2021
    ghc-options: -threaded -rtsopts "-with-rtsopts=-N -A32m"

