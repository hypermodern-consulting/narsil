-- straylint — our own Haskell linter, built on GHC's real parser
-- (ghc-lib-parser), so it sees Template Haskell correctly where tree-sitter /
-- ast-grep cannot. v1 enforces one rule, the `case` ban; it is the seed of a
-- larger analyzer (the narsil of Haskell). Independent of the library.
executable straylint
    import:           warnings
    main-is:          Main.hs
    build-depends:
        base >= 4.16 && < 4.21,
        containers >= 0.6 && < 0.8,
        directory >= 1.3 && < 1.4,
        filepath >= 1.4 && < 1.6,
        ghc-lib-parser >= 9.12 && < 9.13,
        ghc-lib-parser-ex >= 9.12 && < 9.13,
        syb >= 0.7 && < 0.8
    hs-source-dirs:   straylint
    default-language: GHC2021

